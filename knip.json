{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignore": ["**/*.test-d.ts"],
  "ignoreDependencies": ["@btravstack/lefthook", "@btravstack/oxlint"],
  "workspaces": {
    "packages/*": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["typedoc-plugin-markdown", "@btravstack/typedoc"]
    },
    "examples/*": {
      "project": ["src/**/*.ts"]
    },
    "examples/hono-prisma-api": {
      "project": ["src/**/*.ts", "!src/generated/**"],
      "ignoreDependencies": ["@orpc/contract"]
    },
    "docs": {
      "entry": ["scripts/*.ts"],
      "project": ["scripts/**/*.ts"]
    }
  }
}
