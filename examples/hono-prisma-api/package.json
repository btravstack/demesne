{
  "name": "@demesne-examples/hono-prisma-api",
  "private": true,
  "description": "A Hono + oRPC API wired with demesne: zod env, Prisma/Postgres, unthrown Results with end-to-end typed errors",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@orpc/contract": "catalog:",
    "@orpc/server": "catalog:",
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@unthrown/orpc": "catalog:",
    "@unthrown/prisma": "catalog:",
    "demesne": "workspace:*",
    "hono": "catalog:",
    "unthrown": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@btravstack/tsconfig": "catalog:",
    "@orpc/client": "catalog:",
    "@types/node": "catalog:",
    "@unthrown/vitest": "catalog:",
    "prisma": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
