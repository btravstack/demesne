{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "prisma:generate": {
      "cache": false
    },
    "@demesne-examples/hono-prisma-api#typecheck": {
      "dependsOn": ["^build", "prisma:generate"]
    },
    "@demesne-examples/hono-prisma-api#test": {
      "dependsOn": ["^build", "prisma:generate"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:docs": {
      "dependsOn": ["^build"],
      "outputs": ["docs/**"]
    },
    "@demesne/docs#build": {
      "dependsOn": ["^build", "^build:docs"],
      "outputs": [".vitepress/dist/**"]
    }
  }
}
