{
  "name": "@btravstack/start-kernel",
  "version": "0.0.0",
  "private": true,
  "description": "The btravstack start process spine: a zod config layer and a lifecycle host over a demesne graph. demesne wires, unthrown handles errors, 12-factor falls out.",
  "keywords": [
    "12-factor",
    "config",
    "demesne",
    "dependency-injection",
    "lifecycle",
    "typescript",
    "unthrown"
  ],
  "homepage": "https://github.com/btravstack/demesne#readme",
  "bugs": {
    "url": "https://github.com/btravstack/demesne/issues"
  },
  "license": "MIT",
  "author": "Benoit TRAVERS <benoit.travers.fr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btravstack/demesne.git",
    "directory": "packages/start-kernel"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "build:docs": "typedoc",
    "check:package": "publint --strict && attw --pack .",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:types": "tsc --noEmit -p tsconfig.test-d.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test-d.json"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@demesne/tsconfig": "workspace:*",
    "@demesne/typedoc": "workspace:*",
    "@types/node": "catalog:",
    "@unthrown/vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "demesne": "workspace:*",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-markdown": "catalog:",
    "typescript": "catalog:",
    "unthrown": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "demesne": "workspace:^",
    "unthrown": "^4.1.0",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=22.19"
  }
}
